{
  "builds": [
    {
      "src": "api/market.py",
      "use": "@vercel/python",
      "config": { "maxDuration": 30 }
    },
    {
      "src": "api/chat.py",
      "use": "@vercel/python",
      "config": { "maxDuration": 60 }
    },
    {
      "src": "api/snapshot.py",
      "use": "@vercel/python",
      "config": { "maxDuration": 30 }
    },
    {
      "src": "api/push.py",
      "use": "@vercel/python",
      "config": { "maxDuration": 15 }
    },
    {
      "src": "api/notify.py",
      "use": "@vercel/python",
      "config": { "maxDuration": 30 }
    },
    {
      "src": "api/intraday.py",
      "use": "@vercel/python",
      "config": { "maxDuration": 30 }
    },
    {
      "src": "api/research.py",
      "use": "@vercel/python",
      "config": { "maxDuration": 30 }
    },
    {
      "src": "api/watchlist.py",
      "use": "@vercel/python",
      "config": { "maxDuration": 15 }
    },
    {
      "src": "api/settings.py",
      "use": "@vercel/python",
      "config": { "maxDuration": 15 }
    },
    {
      "src": "api/trigger_intelligence.py",
      "use": "@vercel/python",
      "config": { "maxDuration": 15 }
    },
    {
      "src": "api/pod_listened.py",
      "use": "@vercel/python",
      "config": { "maxDuration": 15 }
    },
    {
      "src": "api/quote.py",
      "use": "@vercel/python",
      "config": { "maxDuration": 15 }
    },
    {
      "src": "**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/market",               "dest": "/api/market.py"               },
    { "src": "/api/chat",                 "dest": "/api/chat.py"                 },
    { "src": "/api/snapshot",             "dest": "/api/snapshot.py"             },
    { "src": "/api/push",                 "dest": "/api/push.py"                 },
    { "src": "/api/notify",               "dest": "/api/notify.py"               },
    { "src": "/api/intraday",             "dest": "/api/intraday.py"             },
    { "src": "/api/research",             "dest": "/api/research.py"             },
    { "src": "/api/watchlist",            "dest": "/api/watchlist.py"            },
    { "src": "/api/settings",             "dest": "/api/settings.py"             },
    { "src": "/api/trigger_intelligence", "dest": "/api/trigger_intelligence.py" },
    { "src": "/api/pod_listened",         "dest": "/api/pod_listened.py"         },
    { "src": "/api/quote",                "dest": "/api/quote.py"                }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    }
  ]
}
